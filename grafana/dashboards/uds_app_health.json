        {"matcher": {"id": "byName", "options": "analysis_text"},"properties": [{"id": "custom.width","value": 500}]}]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "options": {"showHeader": true},
      "targets": [{"format": "table","rawSql": "SELECT a.id, a.timestamp, a.event_id, e.sensor_name, e.event_type, e.severity, a.status, a.confidence, a.model_used, a.analysis_text, a.suggested_actions FROM ai_analyses a JOIN events e ON a.event_id = e.id WHERE e.vessel_id = '$vessel' ORDER BY a.timestamp DESC LIMIT 5","refId": "A"}],
      "title": "Latest AI Analyses",
      "type": "table"
    },
    {
      "datasource": {"type": "postgres", "uid": "timescaledb"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"},"custom": {"fillOpacity": 80,"lineWidth": 1},"thresholds": {"mode": "absolute","steps": [{"color": "red","value": null},{"color": "yellow","value": 120},{"color": "green","value": 0}]},"unit": "s"},"overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "id": 2,
      "options": {"colorMode": "value","graphMode": "none","reduceOptions": {"calcs": ["lastNotNull"],"fields": "","values": false}},
      "targets": [{"format": "table","rawSql": "SELECT AVG(EXTRACT(EPOCH FROM (a.timestamp - e.timestamp))) AS value FROM ai_analyses a JOIN events e ON a.event_id = e.id WHERE e.vessel_id = '$vessel' AND a.timestamp > NOW() - INTERVAL '1 hour'","refId": "A"}],
      "title": "Avg Analysis Latency (s, 1h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "postgres", "uid": "timescaledb"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"},"thresholds": {"mode": "absolute","steps": [{"color": "red","value": null},{"color": "yellow","value": 5},{"color": "green","value": 0}]},"unit": "percent"},"overrides": []},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1},
      "id": 3,
      "options": {"colorMode": "value","graphMode": "none","reduceOptions": {"calcs": ["lastNotNull"],"fields": "","values": false}},
      "targets": [{"format": "table","rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN a.status != 'completed' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0),2) AS value FROM ai_analyses a JOIN events e ON a.event_id = e.id WHERE e.vessel_id = '$vessel' AND a.timestamp > NOW() - INTERVAL '1 hour'","refId": "A"}],
      "title": "Analysis Error Rate (1h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "postgres", "uid": "timescaledb"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"},"custom": {"fillOpacity": 80,"lineWidth": 1},"unit": "short"},"overrides": []},
      "gridPos": {"h": 5, "w": 12, "x": 0, "y": 6},
      "id": 4,
      "options": {"legend": {"displayMode": "list","placement": "bottom"},"tooltip": {"mode": "single"}},
      "targets": [{"format": "time_series","rawSql": "SELECT time_bucket('1 minute', timestamp) AS \"time\", COUNT(*) AS records FROM telemetry WHERE vessel_id = '$vessel' AND timestamp > NOW() - INTERVAL '1 hour' GROUP BY 1 ORDER BY 1","refId": "A"}],
      "title": "Telemetry Ingestion Rate (1h)",
      "type": "barchart"
    },
    {
      "datasource": {"type": "postgres", "uid": "timescaledb"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"},"custom": {"fillOpacity": 80,"lineWidth": 1},"unit": "short"},"overrides": []},
      "gridPos": {"h": 5, "w": 12, "x": 12, "y": 6},
      "id": 5,
      "options": {"legend": {"displayMode": "list","placement": "bottom"},"tooltip": {"mode": "single"}},
      "targets": [{"format": "time_series","rawSql": "SELECT time_bucket('1 minute', timestamp) AS \"time\", COUNT(*) AS events FROM events WHERE vessel_id = '$vessel' AND timestamp > NOW() - INTERVAL '1 hour' GROUP BY 1 ORDER BY 1","refId": "A"}],
      "title": "Event Rate (1h)",
      "type": "barchart"
    },
    {
      "datasource": {"type": "postgres", "uid": "timescaledb"},
      "fieldConfig": {"defaults": {"custom": {"displayMode": "auto"},"color": {"mode": "thresholds","thresholds": {"mode": "absolute","steps": [{"color": "red","value": null},{"color": "yellow","value": 10},{"color": "green","value": 0}]}}},"overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 11},
      "id": 6,
      "options": {"showHeader": true},
      "targets": [{"format": "table","rawSql": "SELECT id, timestamp, vessel_id, sensor_name, event_type, severity, details FROM events WHERE vessel_id = '$vessel' AND acknowledged = FALSE ORDER BY timestamp DESC LIMIT 25","refId": "A"}],
      "title": "Unacknowledged Alarms",
      "type": "table"
