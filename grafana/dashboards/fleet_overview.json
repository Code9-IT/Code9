        "showHeader": true,
        "sortBy": [{"displayName": "Severity", "desc": true}],
        "footer": {"show": false}
      },
      "targets": [{
        "format": "table",
        "rawSql": "SELECT u.name AS \"Vessel\", u.imo_nr AS \"IMO\", a.name AS \"Application\", al.alert_name AS \"Alert\", al.severity AS \"Severity\", al.status AS \"Status\", al.alert_type AS \"Type\", to_char(al.starts_at, 'YYYY-MM-DD HH24:MI') AS \"Started\", CASE WHEN al.ends_at IS NOT NULL THEN ROUND(EXTRACT(EPOCH FROM (al.ends_at - al.starts_at)) / 60)::text || ' min' ELSE ROUND(EXTRACT(EPOCH FROM (NOW() - al.starts_at)) / 60)::text || ' min (ongoing)' END AS \"Duration\", COALESCE(al.annotations->>'summary', '') AS \"Summary\" FROM alerts al JOIN udslocations u ON u.id = al.uds_location_id LEFT JOIN applications a ON a.id = al.application_id WHERE al.status = 'firing' AND (al.ends_at IS NULL OR al.ends_at > NOW()) ORDER BY CASE al.severity WHEN 'critical' THEN 0 WHEN 'warning' THEN 1 ELSE 2 END ASC, al.starts_at DESC",
        "refId": "A"
      }],
      "title": "Active Alerts Across Fleet",
      "type": "table"
    },
