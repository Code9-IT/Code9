      "id": 32,
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "Affected Vessels", "desc": true}],
        "footer": {"show": false}
      },
      "targets": [{
        "format": "table",
        "rawSql": "SELECT al.alert_name AS \"Alert Type\", al.alert_type AS \"Category\", COUNT(DISTINCT u.imo_nr) AS \"Affected Vessels\", STRING_AGG(DISTINCT u.name || ' (' || u.imo_nr || ')', ', ' ORDER BY u.name || ' (' || u.imo_nr || ')') AS \"Vessels\", STRING_AGG(DISTINCT a.name, ', ') AS \"Applications\" FROM alerts al JOIN udslocations u ON u.id = al.uds_location_id LEFT JOIN applications a ON a.id = al.application_id WHERE al.status = 'firing' AND (al.ends_at IS NULL OR al.ends_at > NOW()) GROUP BY al.alert_name, al.alert_type HAVING COUNT(DISTINCT u.imo_nr) > 1 ORDER BY COUNT(DISTINCT u.imo_nr) DESC, al.alert_name ASC",
        "refId": "A"
      }],
      "title": "Correlated Alert Types (Same Alert on Multiple Vessels)",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 33},
      "id": 40,
      "title": "Fleet Connectivity",
      "type": "row"
    },
    {
      "datasource": {"type": "postgres", "uid": "timescaledb"},
      "fieldConfig": {
        "defaults": {
          "custom": {"displayMode": "auto", "filterable": true},
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Connectivity"},
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {"type": "value", "options": {"Fresh": {"text": "Fresh", "color": "green"}}},
                  {"type": "value", "options": {"Delayed": {"text": "Delayed", "color": "orange"}}},
                  {"type": "value", "options": {"Stale": {"text": "Stale", "color": "red"}}}
                ]
              },
              {"id": "custom.displayMode", "value": "color-background-solid"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Sync Age"},
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "orange", "value": 300},
                    {"color": "red", "value": 1800}
                  ]
                }
              },
              {"id": "custom.displayMode", "value": "color-background-solid"},
              {"id": "unit", "value": "s"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Vessel"},
            "properties": [
              {"id": "links", "value": [
                {
                  "title": "Drill down to vessel",
                  "url": "/d/maritime_uds_app_health/uds-app-health?var-vessel=${__data.fields[\"IMO\"]}",
                  "targetBlank": false
                }
              ]}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 34},
      "id": 41,
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "Connectivity", "desc": false}],
        "footer": {"show": false}
      },
      "targets": [{
        "format": "table",
        "rawSql": "WITH latest_sync AS ( SELECT ms.imo_nr, MAX(ms.time) AS latest_metric_time, AVG(CASE WHEN ms.metric_name = 'last_sync_age_seconds' THEN ms.value END) AS avg_sync_age, MAX(CASE WHEN ms.metric_name = 'reporting_stale' THEN ms.value END) AS reporting_stale, MAX(CASE WHEN ms.metric_name = 'sync_delayed' THEN ms.value END) AS sync_delayed FROM metric_samples ms WHERE ms.metric_name IN ('last_sync_age_seconds', 'reporting_stale', 'sync_delayed') AND ms.time > NOW() - INTERVAL '2 hours' GROUP BY ms.imo_nr ) SELECT u.name AS \"Vessel\", u.imo_nr AS \"IMO\", to_char(ls.latest_metric_time, 'YYYY-MM-DD HH24:MI:SS') AS \"Latest Metric\", ROUND(EXTRACT(EPOCH FROM (NOW() - ls.latest_metric_time)))::int AS \"Freshness (s)\", ROUND(COALESCE(ls.avg_sync_age, 0))::int AS \"Sync Age\", CASE WHEN COALESCE(ls.reporting_stale, 0) >= 1 THEN 'Stale' WHEN COALESCE(ls.sync_delayed, 0) >= 1 THEN 'Delayed' WHEN ls.latest_metric_time IS NULL THEN 'Stale' WHEN EXTRACT(EPOCH FROM (NOW() - ls.latest_metric_time)) > 1800 THEN 'Stale' WHEN EXTRACT(EPOCH FROM (NOW() - ls.latest_metric_time)) > 600 THEN 'Delayed' ELSE 'Fresh' END AS \"Connectivity\", COALESCE(stale_apps.cnt, 0) AS \"Stale Apps\", COALESCE(delayed_apps.cnt, 0) AS \"Delayed Apps\" FROM udslocations u LEFT JOIN latest_sync ls ON ls.imo_nr = u.imo_nr LEFT JOIN LATERAL ( SELECT COUNT(DISTINCT ms2.app_id)::int AS cnt FROM metric_samples ms2 WHERE ms2.imo_nr = u.imo_nr AND ms2.metric_name = 'reporting_stale' AND ms2.value >= 1 AND ms2.time > NOW() - INTERVAL '2 hours' ) stale_apps ON true LEFT JOIN LATERAL ( SELECT COUNT(DISTINCT ms3.app_id)::int AS cnt FROM metric_samples ms3 WHERE ms3.imo_nr = u.imo_nr AND ms3.metric_name = 'sync_delayed' AND ms3.value >= 1 AND ms3.time > NOW() - INTERVAL '2 hours' ) delayed_apps ON true ORDER BY CASE WHEN COALESCE(ls.reporting_stale, 0) >= 1 THEN 0 WHEN COALESCE(ls.sync_delayed, 0) >= 1 THEN 1 ELSE 2 END ASC, u.name ASC",
        "refId": "A"
      }],
      "title": "Fleet Connectivity Status",
      "type": "table"
    },
