      "id": 10,
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "Active Alerts", "desc": true}],
        "footer": {"show": false}
      },
      "targets": [{
        "format": "table",
        "rawSql": "SELECT u.name AS \"Vessel\", u.imo_nr AS \"IMO\", COUNT(DISTINCT CASE WHEN al.status = 'firing' AND (al.ends_at IS NULL OR al.ends_at > NOW()) THEN al.id END) AS \"Active Alerts\", COUNT(DISTINCT CASE WHEN al.status = 'firing' AND al.severity = 'critical' AND (al.ends_at IS NULL OR al.ends_at > NOW()) THEN al.id END) AS \"Critical\", COUNT(DISTINCT CASE WHEN al.status = 'firing' AND (al.ends_at IS NULL OR al.ends_at > NOW()) THEN al.application_id END) AS \"Affected Apps\", (SELECT COUNT(*) FROM uds_location_application_instances WHERE uds_location_id = u.id) AS \"Total Apps\", CASE WHEN COUNT(DISTINCT CASE WHEN al.status = 'firing' AND al.severity = 'critical' AND (al.ends_at IS NULL OR al.ends_at > NOW()) THEN al.id END) > 0 THEN 'critical' WHEN COUNT(DISTINCT CASE WHEN al.status = 'firing' AND (al.ends_at IS NULL OR al.ends_at > NOW()) THEN al.id END) > 0 THEN 'degraded' ELSE 'healthy' END AS \"Status\", to_char(MAX(ms.time), 'YYYY-MM-DD HH24:MI:SS') AS \"Latest Metric\" FROM udslocations u LEFT JOIN alerts al ON al.uds_location_id = u.id LEFT JOIN metric_samples ms ON ms.imo_nr = u.imo_nr GROUP BY u.id, u.name, u.imo_nr ORDER BY \"Active Alerts\" DESC, u.name ASC",
        "refId": "A"
      }],
      "title": "Fleet Vessel Status",
      "type": "table"
    },
