        "rawSql": "SELECT time_bucket('30 minutes', al.starts_at) AS \"time\", u.name AS metric, COUNT(*) AS value FROM alerts al JOIN udslocations u ON u.id = al.uds_location_id WHERE al.starts_at > NOW() - INTERVAL '6 hours' GROUP BY 1, u.name ORDER BY 1",
        "refId": "A"
      }],
      "title": "Alerts Over Time by Vessel (6h)",
      "type": "timeseries"
    }
