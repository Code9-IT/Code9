            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "green", "value": null},
                    {"color": "orange", "value": 2},
                    {"color": "red", "value": 3}
                  ]
                }
              },
              {"id": "custom.displayMode", "value": "color-background-solid"}
            ]
          }
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
      "id": 31,
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "Affected Vessels", "desc": true}],
        "footer": {"show": false}
      },
      "targets": [{
        "format": "table",
        "rawSql": "SELECT a.external_id AS \"App ID\", a.name AS \"Application\", COUNT(DISTINCT u.imo_nr) AS \"Affected Vessels\", STRING_AGG(DISTINCT u.name || ' (' || u.imo_nr || ')', ', ' ORDER BY u.name || ' (' || u.imo_nr || ')') AS \"Vessels\", STRING_AGG(DISTINCT al.alert_name, ', ') AS \"Alert Types\", STRING_AGG(DISTINCT al.severity, ', ') AS \"Severities\" FROM alerts al JOIN udslocations u ON u.id = al.uds_location_id JOIN applications a ON a.id = al.application_id WHERE al.status = 'firing' AND (al.ends_at IS NULL OR al.ends_at > NOW()) GROUP BY a.external_id, a.name HAVING COUNT(DISTINCT u.imo_nr) > 1 ORDER BY COUNT(DISTINCT u.imo_nr) DESC, a.name ASC",
        "refId": "A"
      }],
      "title": "Correlated App Issues (Same App on Multiple Vessels)",
      "type": "table"
    },
    {
